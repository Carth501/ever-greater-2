{
	"name": "ever-greater",
	"private": true,
	"engines": {
		"node": ">=20 <21"
	},
	"scripts": {
		"client": "npm --prefix ever-greater-client start",
		"server": "npm --prefix ever-greater-server start",
		"server:dev": "npm --prefix ever-greater-server run dev",
		"dev": "npm-run-all --parallel server:dev client",
		"kill": "powershell -Command \"$process = Get-NetTCPConnection -LocalPort 4000 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -First 1; if ($process) { Stop-Process -Id $process -Force; Write-Host 'Killed process on port 4000' } else { Write-Host 'No process found on port 4000' }\"",
		"check:shared-deps": "node scripts/check-shared-deps.cjs",
		"check:client-slice-boundaries": "node scripts/check-client-slice-boundaries.cjs",
		"check:client-typecheck": "npm --prefix ever-greater-client run typecheck",
		"check:client-test-typecheck": "npm --prefix ever-greater-client run typecheck:tests",
		"guardrails": "npm-run-all check:shared-deps check:client-slice-boundaries check:client-typecheck",
		"test": "npm-run-all guardrails test:shared test:server test:client",
		"test:shared": "npm --prefix ever-greater-shared test",
		"test:server": "npm --prefix ever-greater-server test",
		"test:client": "npm --prefix ever-greater-client run test -- --run"
	},
	"devDependencies": {
		"npm-run-all": "^4.1.5"
	}
}