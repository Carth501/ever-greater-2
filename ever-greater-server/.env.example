# Required: PostgreSQL database configuration
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Optional in local development, required in production
SESSION_SECRET=local-dev-session-secret

# Optional: Server port
# PORT=4000

# Optional: Connection Pool Settings
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT=30000

# Optional: Comma-separated list of allowed browser origins for CORS
# Example: CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000
# CLIENT_URL=http://localhost:3000

# Optional: Starting printer supplies for newly created users
# STARTING_PRINTER_SUPPLIES=1000
