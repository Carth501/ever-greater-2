{
	"name": "ever-greater-server",
	"version": "1.0.0",
	"private": true,
	"main": "dist/index.js",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
		"start": "npm run build && node dist/index.js",
		"dev": "tsx watch src/index.ts",
		"migrate": "tsx src/migrate.ts",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"test:coverage": "vitest run --coverage",
		"clean": "rimraf dist",
		"kill": "powershell -Command \"$process = Get-NetTCPConnection -LocalPort 4000 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -First 1; if ($process) { Stop-Process -Id $process -Force; Write-Host 'Killed process on port 4000' } else { Write-Host 'No process found on port 4000' }\""
	},
	"dependencies": {
		"bcryptjs": "^3.0.3",
		"connect-pg-simple": "^10.0.0",
		"cors": "^2.8.5",
		"dotenv": "^17.3.1",
		"ever-greater-shared": "file:../ever-greater-shared",
		"express": "^4.19.2",
		"express-session": "^1.19.0",
		"pg": "^8.18.0",
		"ws": "^8.18.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/connect-pg-simple": "^7.0.3",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/express-session": "^1.18.0",
		"@types/node": "^20.0.0",
		"@types/pg": "^8.11.0",
		"@types/ws": "^8.5.10",
		"rimraf": "^5.0.0",
		"supertest": "^7.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5.7.3",
		"vitest": "^4.0.18"
	}
}