{
	"name": "ever-greater-shared",
	"version": "1.0.0",
	"description": "Shared types and definitions for ever-greater client and server",
	"type": "module",
	"engines": {
		"node": ">=20 <21"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "npm run clean && tsc",
		"prepare": "npm run build",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"watch": "tsc --watch",
		"clean": "rimraf dist"
	},
	"keywords": [
		"shared",
		"types"
	],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"vitest": "^4.0.18",
		"typescript": "^5.7.3",
		"rimraf": "^5.0.0"
	}
}